// Prestige Garage AI-OS — Prisma Schema
// SQLite database for local + Vercel deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════════
// 🎞️ PPF Rolls Inventory — جرد البروتيكشن
// ════════════════════════════════════════════════════════════════

model Roll {
  id            String   @id @default(cuid())
  code          String   @unique
  brand         String
  type          String
  model         String?
  width         Float?
  totalLength   Float
  remainingLength Float? // calculated: totalLength - sum(consumptions.metersUsed + waste)
  price         Float?
  supplier      String?
  purchaseDate  DateTime?
  notes         String?
  status        String   @default("active") // active | low | finished
  createdAt     DateTime @default(now())

  consumptions  RollConsumption[]

  @@map("rolls")
}

model RollConsumption {
  id            String   @id @default(cuid())
  rollId        String
  rollCode      String
  date          DateTime
  clientName    String?
  carType       String?
  plateNumber   String?
  metersUsed    Float
  waste         Float    @default(0)
  usageArea     String?
  workOrder     String?
  notes         String?
  technician    String?
  transactionType String? @default("استهلاك")
  createdAt     DateTime @default(now())

  roll          Roll     @relation(fields: [rollId], references: [id], onDelete: Cascade)

  @@map("roll_consumptions")
}

// ════════════════════════════════════════════════════════════════
// 👷 Employees — حسابات الموظفين
// ════════════════════════════════════════════════════════════════

model Employee {
  id            String   @id @default(cuid())
  name          String   @unique
  baseSalary    Float
  phone         String?
  hireDate      DateTime?
  jobTitle      String?
  status        String   @default("نشط") // نشط | متوقف
  notes         String?
  createdAt     DateTime @default(now())

  attendance    Attendance[]
  advances      Advance[]
  commissions   Commission[]

  @@map("employees")
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  employeeName  String
  date          DateTime
  status        String   // ح=حضور | غ=غياب | إ=إجازة رسمية | ر=إجازة أسبوعية
  month         Int
  year          Int
  penalties     Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendance")
}

model Commission {
  id            String   @id @default(cuid())
  employeeId    String
  employeeName  String
  date          DateTime?
  month         Int?
  year          Int?
  monthLabel    String?  // "يونيو" etc.
  clientName    String?
  carType       String?
  serviceType   String?
  serviceCategory String?
  amount        Float
  notes         String?
  createdAt     DateTime @default(now())

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("commissions")
}

model Advance {
  id            String   @id @default(cuid())
  employeeId    String
  employeeName  String
  date          DateTime
  amount        Float
  notes         String?
  month         Int
  year          Int
  createdAt     DateTime @default(now())

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("advances")
}

// ════════════════════════════════════════════════════════════════
// 📦 Stock Management — المخزون والخامات
// ════════════════════════════════════════════════════════════════

model StockItem {
  id            String   @id @default(cuid())
  name          String
  category      String   // ديتيلنج | بوليش وكوتينج | أدوات ومعدات
  unit          String   // لتر | عبوة | وحدة
  totalReceived Float    @default(0)
  totalWithdrawn Float   @default(0)
  currentQty    Float    @default(0)
  minLevel      Float    @default(0)
  status        String   @default("كافي") // كافي | منخفض | نفد
  unitPrice     Float    @default(0)
  createdAt     DateTime @default(now())

  movements     StockMovement[]

  @@map("stock_items")
}

model StockMovement {
  id            String   @id @default(cuid())
  itemId        String?
  itemName      String
  date          DateTime
  materialType  String?
  movementType  String   // استلام | سحب
  quantity      Float
  unit          String?
  unitPrice     Float    @default(0)
  totalCost     Float    @default(0)
  notes         String?
  deliveryNote  String?
  createdAt     DateTime @default(now())

  item          StockItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

// ════════════════════════════════════════════════════════════════
// 🔧 Services & Invoices — الخدمات والفواتير
// ════════════════════════════════════════════════════════════════

model Service {
  id            String   @id @default(cuid())
  code          String   @unique
  date          DateTime
  plate         String?
  clientName    String?
  carType       String?
  serviceType   String   // ديتيلنج | بوليش | نانو | بروتيكشن | عزل حراري | أخرى
  serviceCategory String? // for dashboard classification
  price         Float
  paymentMethod String?
  technician    String?
  notes         String?
  createdAt     DateTime @default(now())

  @@map("services")
}

model Invoice {
  id            String   @id @default(cuid())
  deliveryNote  String   @unique
  date          DateTime?
  description   String?
  total         Float
  discount      Float    @default(0)
  net           Float
  itemsCount    Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())

  @@map("invoices")
}

// ════════════════════════════════════════════════════════════════
// 🤖 AI Conversations & Alerts — محادثات AI والتنبيهات
// ════════════════════════════════════════════════════════════════

model AiConversation {
  id            String   @id @default(cuid())
  userMessage   String
  aiResponse    String
  actionTaken   String?
  intentType    String?  // query | add | report | alert | suggestion
  timestamp     DateTime @default(now())

  @@map("ai_conversations")
}

model Alert {
  id            String   @id @default(cuid())
  type          String   // low_stock | roll_low | advance_overdue | attendance
  severity      String   @default("warning") // info | warning | critical
  title         String
  message       String
  relatedId     String?
  relatedType   String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("alerts")
}
